<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.health.mapper.TMedicationReminderMapper">
    
    <resultMap type="TMedicationReminder" id="TMedicationReminderResult">
        <result property="reminderId"    column="reminder_id"    />
        <result property="elderlyId"    column="elderly_id"    />
        <result property="medicationName"    column="medication_name"    />
        <result property="medicationType"    column="medication_type"    />
        <result property="dosage"    column="dosage"    />
        <result property="frequency"    column="frequency"    />
        <result property="reminderTime"    column="reminder_time"    />
        <result property="startDate"    column="start_date"    />
        <result property="endDate"    column="end_date"    />
        <result property="note"    column="note"    />
        <result property="status"    column="status"    />
        <result property="isDeleted"    column="is_deleted"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectTMedicationReminderVo">
        select reminder_id, elderly_id, medication_name, medication_type, dosage, frequency, reminder_time, start_date, end_date, note, status, is_deleted, create_time, update_time from t_medication_reminder
    </sql>

    <select id="selectTMedicationReminderList" parameterType="TMedicationReminder" resultMap="TMedicationReminderResult">
        <include refid="selectTMedicationReminderVo"/>
        <where>  
            <if test="elderlyId != null "> and elderly_id = #{elderlyId}</if>
            <if test="medicationName != null  and medicationName != ''"> and medication_name like concat('%', #{medicationName}, '%')</if>
            <if test="medicationType != null  and medicationType != ''"> and medication_type = #{medicationType}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectTMedicationReminderByReminderId" parameterType="Long" resultMap="TMedicationReminderResult">
        <include refid="selectTMedicationReminderVo"/>
        where reminder_id = #{reminderId}
    </select>

    <insert id="insertTMedicationReminder" parameterType="TMedicationReminder" useGeneratedKeys="true" keyProperty="reminderId">
        insert into t_medication_reminder
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="elderlyId != null">elderly_id,</if>
            <if test="medicationName != null and medicationName != ''">medication_name,</if>
            <if test="medicationType != null">medication_type,</if>
            <if test="dosage != null">dosage,</if>
            <if test="frequency != null and frequency != ''">frequency,</if>
            <if test="reminderTime != null">reminder_time,</if>
            <if test="startDate != null">start_date,</if>
            <if test="endDate != null">end_date,</if>
            <if test="note != null">note,</if>
            <if test="status != null">status,</if>
            <if test="isDeleted != null">is_deleted,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="elderlyId != null">#{elderlyId},</if>
            <if test="medicationName != null and medicationName != ''">#{medicationName},</if>
            <if test="medicationType != null">#{medicationType},</if>
            <if test="dosage != null">#{dosage},</if>
            <if test="frequency != null and frequency != ''">#{frequency},</if>
            <if test="reminderTime != null">#{reminderTime},</if>
            <if test="startDate != null">#{startDate},</if>
            <if test="endDate != null">#{endDate},</if>
            <if test="note != null">#{note},</if>
            <if test="status != null">#{status},</if>
            <if test="isDeleted != null">#{isDeleted},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateTMedicationReminder" parameterType="TMedicationReminder">
        update t_medication_reminder
        <trim prefix="SET" suffixOverrides=",">
            <if test="elderlyId != null">elderly_id = #{elderlyId},</if>
            <if test="medicationName != null and medicationName != ''">medication_name = #{medicationName},</if>
            <if test="medicationType != null">medication_type = #{medicationType},</if>
            <if test="dosage != null">dosage = #{dosage},</if>
            <if test="frequency != null and frequency != ''">frequency = #{frequency},</if>
            <if test="reminderTime != null">reminder_time = #{reminderTime},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="note != null">note = #{note},</if>
            <if test="status != null">status = #{status},</if>
            <if test="isDeleted != null">is_deleted = #{isDeleted},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where reminder_id = #{reminderId}
    </update>

    <delete id="deleteTMedicationReminderByReminderId" parameterType="Long">
        delete from t_medication_reminder where reminder_id = #{reminderId}
    </delete>

    <delete id="deleteTMedicationReminderByReminderIds" parameterType="String">
        delete from t_medication_reminder where reminder_id in 
        <foreach item="reminderId" collection="array" open="(" separator="," close=")">
            #{reminderId}
        </foreach>
    </delete>
</mapper>