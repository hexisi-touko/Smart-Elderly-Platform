<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.safety.mapper.TSafetyZoneMapper">
    
    <resultMap type="TSafetyZone" id="TSafetyZoneResult">
        <result property="zoneId"    column="zone_id"    />
        <result property="elderlyId"    column="elderly_id"    />
        <result property="zoneName"    column="zone_name"    />
        <result property="centerLng"    column="center_lng"    />
        <result property="centerLat"    column="center_lat"    />
        <result property="radius"    column="radius"    />
        <result property="zoneAddress"    column="zone_address"    />
        <result property="isActive"    column="is_active"    />
        <result property="isDeleted"    column="is_deleted"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectTSafetyZoneVo">
        select zone_id, elderly_id, zone_name, center_lng, center_lat, radius, zone_address, is_active, is_deleted, create_time, update_time from t_safety_zone
    </sql>

    <select id="selectTSafetyZoneList" parameterType="TSafetyZone" resultMap="TSafetyZoneResult">
        <include refid="selectTSafetyZoneVo"/>
        <where>  
            <if test="elderlyId != null "> and elderly_id = #{elderlyId}</if>
            <if test="zoneName != null  and zoneName != ''"> and zone_name like concat('%', #{zoneName}, '%')</if>
            <if test="isActive != null "> and is_active = #{isActive}</if>
        </where>
    </select>
    
    <select id="selectTSafetyZoneByZoneId" parameterType="Long" resultMap="TSafetyZoneResult">
        <include refid="selectTSafetyZoneVo"/>
        where zone_id = #{zoneId}
    </select>

    <insert id="insertTSafetyZone" parameterType="TSafetyZone" useGeneratedKeys="true" keyProperty="zoneId">
        insert into t_safety_zone
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="elderlyId != null">elderly_id,</if>
            <if test="zoneName != null and zoneName != ''">zone_name,</if>
            <if test="centerLng != null">center_lng,</if>
            <if test="centerLat != null">center_lat,</if>
            <if test="radius != null">radius,</if>
            <if test="zoneAddress != null">zone_address,</if>
            <if test="isActive != null">is_active,</if>
            <if test="isDeleted != null">is_deleted,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="elderlyId != null">#{elderlyId},</if>
            <if test="zoneName != null and zoneName != ''">#{zoneName},</if>
            <if test="centerLng != null">#{centerLng},</if>
            <if test="centerLat != null">#{centerLat},</if>
            <if test="radius != null">#{radius},</if>
            <if test="zoneAddress != null">#{zoneAddress},</if>
            <if test="isActive != null">#{isActive},</if>
            <if test="isDeleted != null">#{isDeleted},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateTSafetyZone" parameterType="TSafetyZone">
        update t_safety_zone
        <trim prefix="SET" suffixOverrides=",">
            <if test="elderlyId != null">elderly_id = #{elderlyId},</if>
            <if test="zoneName != null and zoneName != ''">zone_name = #{zoneName},</if>
            <if test="centerLng != null">center_lng = #{centerLng},</if>
            <if test="centerLat != null">center_lat = #{centerLat},</if>
            <if test="radius != null">radius = #{radius},</if>
            <if test="zoneAddress != null">zone_address = #{zoneAddress},</if>
            <if test="isActive != null">is_active = #{isActive},</if>
            <if test="isDeleted != null">is_deleted = #{isDeleted},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where zone_id = #{zoneId}
    </update>

    <delete id="deleteTSafetyZoneByZoneId" parameterType="Long">
        delete from t_safety_zone where zone_id = #{zoneId}
    </delete>

    <delete id="deleteTSafetyZoneByZoneIds" parameterType="String">
        delete from t_safety_zone where zone_id in 
        <foreach item="zoneId" collection="array" open="(" separator="," close=")">
            #{zoneId}
        </foreach>
    </delete>
</mapper>