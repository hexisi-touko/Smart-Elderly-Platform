<mapper namespace="com.ruoyi.safety.mapper.TSafetyAlertMapper">
    
    <resultMap type="TSafetyAlert" id="TSafetyAlertResult">
        <result property="alertId"    column="alert_id"    />
        <result property="elderlyId"    column="elderly_id"    />
