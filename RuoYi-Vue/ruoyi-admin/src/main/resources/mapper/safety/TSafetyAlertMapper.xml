    <sql id="selectTSafetyAlertVo">
        select alert_id, elderly_id, device_id, alert_type, alert_time, response_time, complete_time, urge_count, handler_id, handler_role, alert_lng, alert_lat, alert_address, alert_status, handle_result, emergency_order_id, is_deleted, create_time, update_time from t_safety_alert
    </sql>

    <select id="selectTSafetyAlertList" parameterType="TSafetyAlert" resultMap="TSafetyAlertResult">
        <include refid="selectTSafetyAlertVo"/>
        <where>  
            <if test="elderlyId != null "> and elderly_id = #{elderlyId}</if>
            <if test="deviceId != null "> and device_id = #{deviceId}</if>
            <if test="alertType != null  and alertType != ''"> and alert_type = #{alertType}</if>
            <if test="params.beginAlertTime != null and params.beginAlertTime != '' and params.endAlertTime != null and params.endAlertTime != ''"> and alert_time between #{params.beginAlertTime} and #{params.endAlertTime}</if>
            <if test="handlerRole != null "> and handler_role = #{handlerRole}</if>
            <if test="alertStatus != null "> and alert_status = #{alertStatus}</if>
        </where>
    </select>
    
    <select id="selectTSafetyAlertByAlertId" parameterType="Long" resultMap="TSafetyAlertResult">
        <include refid="selectTSafetyAlertVo"/>
        where alert_id = #{alertId}
    </select>

    <insert id="insertTSafetyAlert" parameterType="TSafetyAlert" useGeneratedKeys="true" keyProperty="alertId">
