    <delete id="deleteTSafetyAlertByAlertId" parameterType="Long">
        delete from t_safety_alert where alert_id = #{alertId}
    </delete>

    <delete id="deleteTSafetyAlertByAlertIds" parameterType="String">
        delete from t_safety_alert where alert_id in 
        <foreach item="alertId" collection="array" open="(" separator="," close=")">
            #{alertId}
        </foreach>
    </delete>
