<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.spirit.mapper.TOnlineCourseMapper">
    
    <resultMap type="TOnlineCourse" id="TOnlineCourseResult">
        <result property="courseId"    column="course_id"    />
        <result property="courseName"    column="course_name"    />
        <result property="courseType"    column="course_type"    />
        <result property="courseDescription"    column="course_description"    />
        <result property="instructor"    column="instructor"    />
        <result property="courseCover"    column="course_cover"    />
        <result property="videoUrl"    column="video_url"    />
        <result property="duration"    column="duration"    />
        <result property="maxEnrollment"    column="max_enrollment"    />
        <result property="currentEnrollment"    column="current_enrollment"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="status"    column="status"    />
        <result property="isDeleted"    column="is_deleted"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectTOnlineCourseVo">
        select course_id, course_name, course_type, course_description, instructor, course_cover, video_url, duration, max_enrollment, current_enrollment, start_time, end_time, status, is_deleted, create_time, update_time from t_online_course
    </sql>

    <select id="selectTOnlineCourseList" parameterType="TOnlineCourse" resultMap="TOnlineCourseResult">
        <include refid="selectTOnlineCourseVo"/>
        <where>  
            <if test="courseName != null  and courseName != ''"> and course_name like concat('%', #{courseName}, '%')</if>
            <if test="courseType != null  and courseType != ''"> and course_type = #{courseType}</if>
            <if test="instructor != null  and instructor != ''"> and instructor like concat('%', #{instructor}, '%')</if>
            <if test="params.beginStartTime != null and params.beginStartTime != '' and params.endStartTime != null and params.endStartTime != ''"> and start_time between #{params.beginStartTime} and #{params.endStartTime}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectTOnlineCourseByCourseId" parameterType="Long" resultMap="TOnlineCourseResult">
        <include refid="selectTOnlineCourseVo"/>
        where course_id = #{courseId}
    </select>

    <insert id="insertTOnlineCourse" parameterType="TOnlineCourse" useGeneratedKeys="true" keyProperty="courseId">
        insert into t_online_course
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="courseName != null and courseName != ''">course_name,</if>
            <if test="courseType != null and courseType != ''">course_type,</if>
            <if test="courseDescription != null">course_description,</if>
            <if test="instructor != null">instructor,</if>
            <if test="courseCover != null">course_cover,</if>
            <if test="videoUrl != null">video_url,</if>
            <if test="duration != null">duration,</if>
            <if test="maxEnrollment != null">max_enrollment,</if>
            <if test="currentEnrollment != null">current_enrollment,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="status != null">status,</if>
            <if test="isDeleted != null">is_deleted,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="courseName != null and courseName != ''">#{courseName},</if>
            <if test="courseType != null and courseType != ''">#{courseType},</if>
            <if test="courseDescription != null">#{courseDescription},</if>
            <if test="instructor != null">#{instructor},</if>
            <if test="courseCover != null">#{courseCover},</if>
            <if test="videoUrl != null">#{videoUrl},</if>
            <if test="duration != null">#{duration},</if>
            <if test="maxEnrollment != null">#{maxEnrollment},</if>
            <if test="currentEnrollment != null">#{currentEnrollment},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="status != null">#{status},</if>
            <if test="isDeleted != null">#{isDeleted},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateTOnlineCourse" parameterType="TOnlineCourse">
        update t_online_course
        <trim prefix="SET" suffixOverrides=",">
            <if test="courseName != null and courseName != ''">course_name = #{courseName},</if>
            <if test="courseType != null and courseType != ''">course_type = #{courseType},</if>
            <if test="courseDescription != null">course_description = #{courseDescription},</if>
            <if test="instructor != null">instructor = #{instructor},</if>
            <if test="courseCover != null">course_cover = #{courseCover},</if>
            <if test="videoUrl != null">video_url = #{videoUrl},</if>
            <if test="duration != null">duration = #{duration},</if>
            <if test="maxEnrollment != null">max_enrollment = #{maxEnrollment},</if>
            <if test="currentEnrollment != null">current_enrollment = #{currentEnrollment},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="status != null">status = #{status},</if>
            <if test="isDeleted != null">is_deleted = #{isDeleted},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where course_id = #{courseId}
    </update>

    <delete id="deleteTOnlineCourseByCourseId" parameterType="Long">
        delete from t_online_course where course_id = #{courseId}
    </delete>

    <delete id="deleteTOnlineCourseByCourseIds" parameterType="String">
        delete from t_online_course where course_id in 
        <foreach item="courseId" collection="array" open="(" separator="," close=")">
            #{courseId}
        </foreach>
    </delete>
</mapper>